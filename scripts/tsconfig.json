{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2021",
        "lib": [
            "es2021"
        ],
        "types": [
            "@types/node"
        ],
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": [
        "node_modules"
    ]
}